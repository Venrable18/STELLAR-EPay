# STELLAR-EPay Frontend Configuration
# Copy this file to .env.local and fill in the actual values

# Soroban RPC URL for interacting with Stellar testnet/mainnet
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Pool Contract ID (deployed contract address)
VITE_POOL_CONTRACT_ID=

# Groth16 Verifier Contract ID (deployed contract address)
VITE_VERIFIER_CONTRACT_ID=

# Token ID (USDC or other payment token on Stellar)
VITE_TOKEN_ID=

# Stellar Network Passphrase
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# API Base URL (for future backend integration)
VITE_API_BASE_URL=http://localhost:3000

# Enable debug logging
VITE_DEBUG=false

# Application Environment
VITE_ENV=development
